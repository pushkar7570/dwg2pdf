APP_NAME=cad-text-mover-mvp
APP_ENV=development
API_PREFIX=/v1
# Use exactly one of the following:
# 1) Single key:
# CLOUDCONVERT_API_KEY=replace-me
# 2) Multiple keys in priority order (recommended for automatic failover):
CLOUDCONVERT_API_KEYS=replace-primary,replace-secondary
CLOUDCONVERT_FAILOVER_ENABLED=true
CLOUDCONVERT_KEY_COOLDOWN_SECONDS=900
CLOUDCONVERT_BASE_URL=https://api.cloudconvert.com/v2
SQLITE_PATH=./jobs.sqlite3
STORAGE_ROOT=./storage
WORKER_POLL_INTERVAL_SECONDS=2.0
CLOUDCONVERT_POLL_INTERVAL_SECONDS=2.0
CLOUDCONVERT_TIMEOUT_SECONDS=120.0
RENDER_DPI=180
OCR_DPI=220
OCR_FALLBACK_MIN_NATIVE_ITEMS=1
MAX_ROTATION_DEGREES=15.0
OVERLAP_MOVE_THRESHOLD=0.45
OVERLAP_REVIEW_THRESHOLD=0.25
MAX_RELOCATE_CHARS=120
MAX_UPLOAD_SIZE_MB=100
MIN_MARGIN_SIZE_POINTS=18.0
MARGIN_DENSITY_THRESHOLD=0.015
MAX_PAGE_WAIT_SECONDS=900.0
