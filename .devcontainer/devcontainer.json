{
    "name": "CAD Overlap Fixer",
    "image": "mcr.microsoft.com/devcontainers/python:3.11-bullseye",
    "forwardPorts": [8000, 8501],
    "portsAttributes": {
        "8000": {
            "label": "FastAPI Backend",
            "onAutoForward": "notify"
        },
        "8501": {
            "label": "Streamlit Frontend",
            "onAutoForward": "openBrowser"
        }
    },
    "postCreateCommand": "bash -c 'cd backend && pip install -r requirements.txt && cd ../frontend && pip install -r requirements.txt'",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.pylint",
                "rangav.vscode-thunder-client"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python"
            }
        }
    },
    "remoteEnv": {
        "PYTHONPATH": "/workspaces/cad-overlap-fixer/backend"
    }
}